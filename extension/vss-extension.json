{
  "manifestVersion": 1,
  "id": "azure-pipeline-html-report-viewer",
  "publisher": "charan-s-vayigandla",
  "name": "Azure HTML Report Viewer",
  "version": "1.0.1",
  "description": "HTML and Playwright test report viewer for Azure DevOps Pipelines with screenshots, videos, and rich assets.",
  "public": true,
  "categories": ["Azure Pipelines"],
  "icons": {
    "default": "images/icon.png"
  },
  "tags": [
    "test",
    "reporting",
    "playwright",
    "HTML"
  ],
  "links": {
    "support": {
      "uri": "https://github.com/charanskc/azure-html-report-viewer/issues"
    },
    "repository": {
      "uri": "https://github.com/charanskc/azure-html-report-viewer"
    },
    "license": {
      "uri": "https://github.com/charanskc/azure-html-report-viewer/blob/main/LICENSE.md"
    }
  },
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "content": {
    "details": {
      "path": "overview.md"
    },
    "license": {
      "path": "LICENSE.md"
    }
  },
  "contributions": [
    {
      "id": "html-report-tab",
      "type": "ms.vss-build-web.build-results-tab",
      "targets": ["ms.vss-build-web.build-results-view"],
      "properties": {
        "name": "HTML Report",
        "uri": "dist/report-tab/index.html",
        "supportsTasks": [
          "2dba3e67-36bb-4e1a-8d4a-9c12c8b2c201"
        ]
      }
    },
    {
      "id": "publishHtmlReport",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": {
        "name": "PublishHtmlReport"
      }
    }
  ],
  "files": [
    {
      "path": "../LICENSE.md",
      "packagePath": "LICENSE.md"
    },
    {
      "path": "overview.md",
      "packagePath": "overview.md"
    },
    {
      "path": "../PublishHtmlReport",
      "packagePath": "PublishHtmlReport",
      "addressable": false
    },
    {
      "path": "dist/report-tab",
      "packagePath": "dist/report-tab",
      "addressable": true
    },
    {
      "path": "images",
      "packagePath": "images",
      "addressable": true
    }
  ]
}
